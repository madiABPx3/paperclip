FROM node:22-slim
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
RUN echo '{"name":"test","version":"1.0.0"}' > package.json
RUN echo 'const http = require("http"); const s = http.createServer((req,res) => { res.writeHead(200); res.end("OK"); }); s.listen(3100, "0.0.0.0", () => console.log("listening on 3100"));' > index.js
EXPOSE 3100
CMD ["node", "index.js"]
